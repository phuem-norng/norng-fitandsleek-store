# Copy to scripts/cloudflare-tunnel-app-hostname.env (do not commit secrets)
# Used by scripts/cloudflare-prune-tunnel-dns.sh

# Create at https://dash.cloudflare.com/profile/api-tokens
# Permissions: Zone → DNS → Edit, Zone → Zone → Read
CLOUDFLARE_API_TOKEN=

# Zone root (must match where DNS lives)
CLOUDFLARE_ZONE_NAME=phuemnorng-kalapakteam.space

# Full hostname the tunnel serves (must match ~/.cloudflared/config.yml ingress)
TUNNEL_APP_HOSTNAME=app.fitandsleek.phuemnorng-kalapakteam.space
