# Database
# Docker (repo `docker-compose.yml`): from Windows/Mac HOST use port 5433 (mapped 5433→5432). Inside the PHP container use DB_HOST=db and DB_PORT=5432.
# Native Postgres on machine: usually DB_HOST=127.0.0.1 DB_PORT=5432
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=fitandsleek_v2
DB_USERNAME=postgres
DB_PASSWORD=Norng@123

# Services
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=fitandsleek_bot
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BROADCAST_MESSAGES_PER_SECOND=25
TELEGRAM_BROADCAST_CHUNK_SIZE=100
TELEGRAM_BROADCAST_RETRY_ATTEMPTS=3
TELEGRAM_BROADCAST_ESTIMATED_WORKERS=1
TELEGRAM_BROADCAST_RETENTION_DAYS=30
OTP_DEBUG=true
OTP_EXPIRES_MINUTES=10

# Infrastructure
LOG_CHANNEL=stack
LOG_LEVEL=debug
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
# Image similarity: vectorize service (512-d embeddings) + Qdrant. Sync PG → Qdrant:
#   php artisan qdrant:setup && php artisan qdrant:index-products
#   php artisan qdrant:index-products --only-missing   # skip already indexed
#   php artisan queue:work   # processes SyncProductToQdrant after admin saves
IMAGE_VECTORIZE_URL=http://127.0.0.1:9000/vectorize
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=products
IMAGE_SEARCH_TIMEOUT=120

# Session & Cache
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_DOMAIN=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (Currently logging to storage/logs/laravel.log)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@fitandsleek.local
MAIL_FROM_NAME="${APP_NAME}"

# Frontend Integration
FRONTEND_URL=http://127.0.0.1:5173
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,127.0.0.1:5173,localhost:5173,0.0.0.0:5173
VITE_APP_NAME="${APP_NAME}"