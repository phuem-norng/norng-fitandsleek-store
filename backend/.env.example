APP_NAME="Fit and Sleek"
APP_ENV=local
APP_KEY=base64:WB7exd+Pwqyoc6EhOhCt26cMFbuEz3oQG46UKDn0pms=
APP_DEBUG=true
# Local PHP: 8000. Docker compose maps backend to host port 8001 — use APP_URL there accordingly.
APP_URL=http://127.0.0.1:8001
APP_PORT=8000
SERVER_PORT=8000

# Security & API Keys
# DO NOT share these values publicly
GEMINI_API_KEY=AIzaSyD-sAZ79s76zUjSIZsZ34F9GN5Av0RI1JI
GEMINI_MODEL=gemini-1.0-pro
GOOGLE_VISION_API_KEY=AIzaSyD-sAZ79s76zUjSIZsZ34F9GN5Av0RI1JI

# Admin "Ask AI" — self-hosted Dify → local LLM (Ollama / Llama 3 / DeepSeek)
# https://api.dify.ai (with or without /v1 — Laravel normalizes automatically)
DIFY_BASE_URL=https://api.dify.ai
DIFY_API_KEY=app-xxxxxxxxxxxxxxxx
DIFY_APP_ID=
DIFY_TIMEOUT=120
# Set true after adding a `dashboard_context` input variable in your Dify Chat app
DIFY_USE_INPUTS_ONLY=true

BAKONG_BASE_URL=https://api-bakong.nbc.gov.kh
BAKONG_TOKEN=your_bakong_api_token_here
BAKONG_RECEIVE_ACCOUNT=your_account@bkrt
BAKONG_MERCHANT_NAME="Fitandsleek Clothes Store"
BAKONG_MERCHANT_CITY="Phnom Penh"
BAKONG_CURRENCY=KHR
BAKONG_EXPIRES_IN=300
BAKONG_WEBHOOK_SECRET=
# NBC Bakong Developer Dashboard → Webhook URL (inbound to Render works globally):
# https://api-fitandsleek.onrender.com/api/payments/khqr/webhook
# Copy the secret NBC gives you into BAKONG_WEBHOOK_SECRET above.
BAKONG_VERIFY_SSL=true
# Render/US hosts cannot call NBC Bakong check API directly (errorCode 15).
# Cloudflare Worker (free): paste backend/bakong-proxy/worker-forward.js → Deploy → set URL below.
# BAKONG_PROXY_URL=https://aged-hill-ac57.teamvcnh.workers.dev
# BAKONG_PROXY_STYLE=forward
# Legacy PHP proxy on Cambodia VPS: BAKONG_PROXY_STYLE=legacy + index.php URL + BAKONG_PROXY_SECRET
BAKONG_CA_BUNDLE=
# Used by PHP to spawn the KHQR generator (backend/node-khqr). Docker: image build + compose start run npm ci if needed. Bare metal: php artisan bakong:install-khqr
# KHQR_NODE_BINARY=node

# ABA PayWay
ABA_PAYWAY_MERCHANT_ID=304810
ABA_PAYWAY_API_KEY=
ABA_PAYWAY_API_SECRET=
ABA_PAYWAY_RETURN_URL=
ABA_PAYWAY_CALLBACK_URL=
ABA_PAYWAY_PAYMENT_LINK=https://link.payway.com.kh/ABAPAYzf414921x

# Authentication
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Fallback redirect URIs (OAuth uses the API host from the incoming request when it is allowed).
# Register EVERY callback below in Google Cloud Console → Authorized redirect URIs:
#   http://localhost:8001/api/auth/google/callback
#   http://127.0.0.1:8001/api/auth/google/callback
#   https://fitandsleekapp.kalapak-team.space/api/auth/google/callback
#   https://api-fitandsleek.onrender.com/api/auth/google/callback
#   https://fitandsleek-official-backend.onrender.com/api/auth/google/callback
GOOGLE_REDIRECT_URI=https://fitandsleek-official-backend.onrender.com/api/auth/google/callback
GOOGLE_REDIRECT_URI_LOCAL=http://localhost:8001/api/auth/google/callback
# Comma-separated extra API origins (scheme://host[:port]) if you add more deploy targets
# OAUTH_EXTRA_API_ORIGINS=
# OAUTH_TRUST_ONRENDER_API_HOSTS=true
APP_URL_LOCAL=http://localhost:8001
FRONTEND_URL_LOCAL=http://localhost:5173

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=https://fitandsleek-official-backend.onrender.com/api/auth/facebook/callback
FACEBOOK_REDIRECT_URI_LOCAL=http://localhost:8001/api/auth/facebook/callback

# Database
# --- Local Docker (repo `docker-compose.yml`) ---
# From Windows/Mac HOST use port 5433 (mapped 5433→5432). Inside the PHP container use DB_HOST=db and DB_PORT=5432.
# Native Postgres on machine: usually DB_HOST=127.0.0.1 DB_PORT=5432
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=fitandsleek_v4
DB_USERNAME=postgres
DB_PASSWORD=Norng@123

# --- Neon PostgreSQL (production on Render) ---
# Copy the connection string from Neon Dashboard → Connection details.
# When DATABASE_URL is set, Laravel uses it for the pgsql connection (overrides DB_HOST/PORT/NAME/USER/PASSWORD).
# DATABASE_URL=postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# DB_SSLMODE=require
# Migrate local pgAdmin backup → Neon: pgAdmin Restore, or `pg_restore -d "$DATABASE_URL" backup.dump`

# Services
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=fitandsleek_bot
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=https://fitandsleekapp.kalapak-team.space
TELEGRAM_ADMIN_CHAT_ID=
# Local Docker sets APP_URL=http://localhost — use TELEGRAM_WEBHOOK_URL for artisan telegram:set-webhook
TELEGRAM_BROADCAST_MESSAGES_PER_SECOND=25
TELEGRAM_BROADCAST_CHUNK_SIZE=100
TELEGRAM_BROADCAST_RETRY_ATTEMPTS=3
TELEGRAM_BROADCAST_ESTIMATED_WORKERS=1
TELEGRAM_BROADCAST_RETENTION_DAYS=30
# When true, OTP codes are logged server-side only (never returned to the browser).
OTP_DEBUG=false
OTP_EXPIRES_MINUTES=10

# Infrastructure
LOG_CHANNEL=stack
LOG_LEVEL=debug
BROADCAST_CONNECTION=log

# Media storage
# Local dev without cloud: FILESYSTEM_DISK=public
# Cloudinary (recommended production): FILESYSTEM_DISK=cloudinary
# Cloudflare R2 (optional later — cheaper at scale): FILESYSTEM_DISK=r2
FILESYSTEM_DISK=cloudinary
# When true, failed cloud uploads fall back to local public disk (dev only).
MEDIA_FALLBACK_TO_PUBLIC=true
# Admin profile image upload target disk (defaults to FILESYSTEM_DISK when unset):
ADMIN_PROFILE_IMAGE_DISK=cloudinary
# In production, prefer false so uploads never silently fall back to local Render storage.
ADMIN_PROFILE_IMAGE_FALLBACK_TO_PUBLIC=false

# --- Cloudinary (recommended production storage) ---
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional: used when your Cloudinary account requires/uses unsigned upload preset.
CLOUDINARY_UPLOAD_PRESET=

# --- Cloudflare R2 (S3-compatible; set FILESYSTEM_DISK=r2) ---
# R2 Dashboard → Manage R2 API Tokens → Create API token (Object Read & Write).
# Enable public access: R2.dev subdomain or custom domain → set R2_PUBLIC_URL below.
# CORS on the bucket must allow your Vercel + Render origins.
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=fitandsleek-media
# R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Prefer a Cloudflare CDN custom domain (faster in Cambodia/APAC than *.r2.dev):
# R2_PUBLIC_URL=https://cdn.fitandsleek.online
# R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
# R2_REGION=auto
# R2_USE_PATH_STYLE_ENDPOINT=true
# Optional aliases (same values; used if R2_* vars are unset):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET=
# AWS_ENDPOINT=
# AWS_URL=
# AWS_DEFAULT_REGION=auto
# AWS_USE_PATH_STYLE_ENDPOINT=true
QUEUE_CONNECTION=database
# Scan-to-search: Fitandsleek CLIP (Hugging Face) + Qdrant Cloud. Sync PG → Qdrant:
#   php artisan qdrant:setup && php artisan qdrant:index-products
#   php artisan qdrant:index-products --only-missing   # skip already indexed
#   php artisan queue:work   # processes SyncProductToQdrant after admin saves
FITANDSLEEK_CLIP_ENDPOINT=https://your-space.hf.space/embed
FITANDSLEEK_CLIP_VECTOR_SIZE=512
AI_SERVICE_KEY=
IMAGE_SEARCH_TIMEOUT=25
QDRANT_URL=https://your-cluster.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=products_fitandsleek_512
QDRANT_VECTOR_SIZE=512
VECTOR_PROVIDER=local_clip
# Local Docker fallback (optional; FITANDSLEEK_CLIP_ENDPOINT takes precedence):
# IMAGE_VECTORIZE_URL=http://127.0.0.1:9000/vectorize

# Session & Cache
CACHE_STORE=file
SESSION_DRIVER=file
REDIS_ENABLED=false
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_DOMAIN=127.0.0.1
REDIS_CLIENT=predis
REDIS_SCHEME=tcp
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Production Redis example (Upstash/Render): set these in deployment env vars.
# REDIS_CLIENT=predis
# REDIS_SCHEME=tls
# REDIS_HOST=your-upstash-host.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=your_upstash_password
# REDIS_ENABLED=true
# CACHE_STORE=redis
# SESSION_DRIVER=redis

# Mail — Resend (recommended for production OTP / transactional email)
MAIL_MAILER=resend
RESEND_API_KEY=re_xxxxxxxx
# Test sender (Resend sandbox — can only deliver to your verified inbox)
MAIL_FROM_ADDRESS=onboarding@resend.dev
# Production: verify fitandsleek.online in Resend, then use e.g. no-reply@fitandsleek.online
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ADMIN_ADDRESS=
# Local SMTP alternative (Mailtrap / Gmail)
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=your_smtp_username
# MAIL_PASSWORD=your_smtp_password
# MAIL_ENCRYPTION=tls

# Mobile OAuth deep link (Flutter — must match AppConfig.oauthCallbackUrl)
MOBILE_OAUTH_CALLBACK_URL=fitandsleek://oauth/callback

# Frontend Integration
FRONTEND_URL=http://127.0.0.1:5173
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,127.0.0.1:5173,localhost:5173,0.0.0.0:5173
VITE_APP_NAME="${APP_NAME}"