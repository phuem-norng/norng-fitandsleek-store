# Copy to .env.docker (gitignored) and fill values:
#   cp env.docker.example .env.docker

# NBC API token (same as Render BAKONG_TOKEN)
BAKONG_TOKEN=

# Must match Render BAKONG_PROXY_SECRET
BAKONG_PROXY_SECRET=

# Cloudflare → Tunnels → fitandsleek-bakong-proxy → Install connector → copy token
CLOUDFLARE_TUNNEL_TOKEN=

# Optional local port for curl tests (default 8787)
# BAKONG_PROXY_PORT=8787
