# Vite loads this in `npm run dev` only (`npm run build` uses `.env.production`).
# Use this when the frontend runs on your machine and Laravel runs in Docker (http://127.0.0.1:8001).
# If you only use `docker compose up` for the SPA (static serve on :5173), this file is ignored — the
# image is built with docker-compose build args (browser → localhost:8001). See docker-compose.yml header.

VITE_API_BASE_URL=/api
VITE_PROXY_TARGET=http://127.0.0.1:8001
VITE_BACKEND_ORIGIN=http://127.0.0.1:8001
VITE_WITH_CREDENTIALS=true
