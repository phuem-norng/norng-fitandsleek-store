# =============================================================================
# Localhost first (recommended for `npm run dev` on http://localhost:5173)
# =============================================================================
# Browser calls /api on the Vite origin only — no CORS. Vite forwards to Laravel.
# Copy these lines into frontend/.env and adjust VITE_PROXY_TARGET to your API.
#
# VITE_API_BASE_URL=/api
# VITE_PROXY_TARGET=https://your-laravel-host.example.com
# VITE_BACKEND_ORIGIN=https://your-laravel-host.example.com
# VITE_STORAGE_MEDIA_ORIGIN=https://your-laravel-host.example.com
#
# Local Laravel on this machine (no cloud):
# VITE_API_BASE_URL=/api
# VITE_PROXY_TARGET=http://127.0.0.1:8000
# VITE_BACKEND_ORIGIN=http://127.0.0.1:8000
#
# Docker backend on host (Laravel mapped to 8001):
# VITE_API_BASE_URL=/api
# VITE_PROXY_TARGET=http://127.0.0.1:8001
# VITE_BACKEND_ORIGIN=http://127.0.0.1:8001

# =============================================================================
# Direct API URL (cross-origin from localhost — needs CORS on the server)
# =============================================================================
# VITE_API_BASE_URL=https://your-laravel-host.example.com
# VITE_BACKEND_ORIGIN=https://your-laravel-host.example.com

# =============================================================================
# Cloudflare Tunnel + Vite (see vite.config.js)
# =============================================================================
# VITE_CLOUDFLARE_TUNNEL=1
# VITE_TUNNEL_PUBLIC_HOST=your-subdomain.trycloudflare.com
# Keep VITE_API_BASE_URL=/api and VITE_PROXY_TARGET=… as above.
