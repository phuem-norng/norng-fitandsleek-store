# Copy to `.env` or `.env.local` (gitignored). Never commit real secrets.

NODE_ENV=development

# Laravel API — this app uses these names (not Nuxt / not VITE_API_URL).
VITE_BACKEND_ORIGIN=http://127.0.0.1:8000
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Send cookies to the API (needed for Sanctum/session on another origin).
VITE_WITH_CREDENTIALS=true

# Optional: public media/CDN origin for image URLs (see src/lib/images.js).
# VITE_STORAGE_MEDIA_ORIGIN=

# Cloudflare Turnstile (site key only; secret stays on the backend).
# VITE_TURNSTILE_SITE_KEY=

# Dev: proxy API to Laravel (see vite.config.js).
# VITE_PROXY_TARGET=http://127.0.0.1:8000

# Dev: comma-separated Host headers allowed by Vite (e.g. LAN IP or machine name).
# VITE_EXTRA_ALLOWED_HOSTS=192.168.1.10,my-pc

# Dev: set to 1 to restrict Vite to defaultAllowedHosts + VITE_EXTRA_ALLOWED_HOSTS (otherwise any Host is allowed).
# VITE_STRICT_DEV_HOSTS=1
