# Copy to `.env` or `.env.local` (gitignored). Never commit real secrets.

NODE_ENV=development

# --- API (must match where Laravel actually runs) ---
# Repo `docker-compose.yml`: backend is http://127.0.0.1:8001 (not 8000).
#
# Recommended for `npm run dev`: same-origin `/api` + Vite proxy (avoids CORS; see vite.config.js).
VITE_API_BASE_URL=/api
VITE_PROXY_TARGET=http://127.0.0.1:8001
#
# Optional: used when VITE_API_BASE_URL is NOT a path (e.g. direct calls to Laravel).
VITE_BACKEND_ORIGIN=http://127.0.0.1:8001
#
# Alternative — call Laravel directly (no proxy): uncomment and drop VITE_API_BASE_URL=/api above.
# VITE_BACKEND_ORIGIN=http://127.0.0.1:8001
# VITE_API_BASE_URL=http://127.0.0.1:8001/api

# Send cookies to the API (needed for Sanctum/session on another origin).
VITE_WITH_CREDENTIALS=true

# Public media/CDN origin (Cloudflare R2 public URL or custom domain). Required when FILESYSTEM_DISK=s3.
# VITE_STORAGE_MEDIA_ORIGIN=https://pub-xxxx.r2.dev

# Cloudflare Turnstile (site key only; secret stays on the backend).
# VITE_TURNSTILE_SITE_KEY=

# Dev: comma-separated Host headers allowed by Vite (e.g. LAN IP or machine name).
# VITE_EXTRA_ALLOWED_HOSTS=192.168.1.10,my-pc

# Dev: set to 1 to restrict Vite to defaultAllowedHosts + VITE_EXTRA_ALLOWED_HOSTS (otherwise any Host is allowed).
# VITE_STRICT_DEV_HOSTS=1

# --- Production builds (docker build / npm run build) ---
# If the public SPA and Laravel are on different hosts, set:
#   VITE_BACKEND_ORIGIN=https://your-api-host.example
# For fitandsleek.kalapak-team.space → fitandsleekapp.kalapak-team.space, a runtime map exists in src/lib/backendOrigin.js.
